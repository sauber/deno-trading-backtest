script-source,300,file:///C:/Users/msn/projects/deno-trading-backtest/src/strategies.ts,// A collection of sample strategies\n// Calculate sum of value of positions\nconst value = (positions\x2C tick)=>positions.map((p)=>p.quantity * p.instrument.price(tick)).reduce((a\x2C b)=>a + b\x2C 0);\n/** A strategy to rebalance positions in instrument to target percentages of total value.\x0d\n * For example { Gold: 40\x2C Silver: 40 }\x0d\n * The strategy will initially open 40 positions of each instruments each with 1% of available cash.\x0d\n * If the total value of all open posistion for an instruments\x0d\n * exceeds the target percentage by more than 1%\x2C then positions will be closed one by one\x2C\x0d\n * until total value is less than target+1.\x0d\n * Ditto if the total value is 1% below target value\x2C then additional positions will be opened\x0d\n * with 1% of total account value until value of positions is above target-1;\x0d\n */ export function rebalance(targets) {\n  return (tick\x2C cash\x2C market\x2C portfolio)=>{\n    const orders = [];\n    // Total value of account\n    const total_value = cash + value(portfolio\x2C tick);\n    Object.entries(targets).forEach(([symbol\x2C target])=>{\n      const positions = portfolio.filter((p)=>p.instrument.symbol === symbol);\n      // Total amount invested in target\n      const invested = value(positions\x2C tick);\n      let pct_invested = invested / total_value * 100;\n      // Buy additional positions\n      if (pct_invested < target - 1) {\n        const instrument = market.instruments.find((i)=>i.symbol === symbol);\n        if (instrument) {\n          const count = Math.floor(target - invested / total_value * 100);\n          const amount = total_value / 100;\n          for(let i = 0; i < count; i++){\n            orders.push({\n              instrument\x2C\n              amount\n            });\n          }\n        }\n      }\n      // Sell excessive positions\n      let index = 0;\n      while(pct_invested > target + 1){\n        const position = positions[index];\n        orders.push({\n          position\x2C\n          reason: "Close"\n        });\n        index++;\n        pct_invested -= position.quantity * position.instrument.price(tick) / total_value * 100;\n      }\n    });\n    return orders;\n  };\n}\nexport const doNothing = ()=>[];\nexport const randomTrading = (tick\x2C cash\x2C market\x2C portfolio)=>{\n  const orders = [];\n  // 20% chance of closing a position\n  if (portfolio.length > 0 && Math.random() < 0.2) {\n    const position = portfolio[Math.floor(Math.random() * portfolio.length)];\n    orders.push({\n      position\x2C\n      reason: "Close"\n    });\n  }\n  // 20% chance of opening a position\n  if (Math.random() < 0.2) {\n    const instrument = market.instruments[Math.floor(Math.random() * market.instruments.length)];\n    // Value of portfolio\n    const equity = portfolio.map((p)=>p.quantity * p.instrument.price(tick)).reduce((a\x2C b)=>a + b\x2C 0);\n    const total = equity + cash;\n    // Spend 10% of total value in each new position\n    const amount = total / 10;\n    orders.push({\n      instrument\x2C\n      amount\n    });\n  }\n  return orders;\n};\n
