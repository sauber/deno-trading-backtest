code-creation,Script,10,186045,0x2c7556764e8,213, file:///C:/Users/msn/projects/deno-trading-backtest/src/backtest.ts:1:1,0x1d8d7000da0,~
script-source,299,file:///C:/Users/msn/projects/deno-trading-backtest/src/backtest.ts,/** Amount of money */ /** A tradable instrument */ export class Instrument {\n  series;\n  start;\n  symbol;\n  name;\n  /** Last tick of series */ end;\n  /** First value of series */ first;\n  /** Last value of series */ last;\n  /** Count of ticks in series */ length;\n  constructor(/** Price series */ series\x2C /** First tick of series */ start\x2C /** Symbol of instrument */ symbol\x2C /** Name of instrument (optional) */ name){\n    this.series = series;\n    this.start = start;\n    this.symbol = symbol;\n    this.name = name;\n    this.end = start + series.length - 1;\n    this.first = series[0];\n    this.last = series[series.length - 1];\n    this.length = series.length;\n  }\n  /** Confirm if data is available at tick */ has(tick) {\n    return tick >= this.start && tick <= this.end;\n  }\n  /** Price at tick */ price(tick) {\n    if (!this.has(tick)) {\n      throw new Error(`Error: Price requested for instrument ${this.symbol} at tick ${tick} is outside range [${this.start};${this.end}].`);\n    }\n    return this.series[tick - this.start];\n  }\n}\n/** Instruments available for trading */ export class Market {\n  instruments;\n  /** First tick of instruments */ start;\n  /** Last tick of instruments */ end;\n  /** Count if ticks in market */ length;\n  constructor(/** List of instruments */ instruments){\n    this.instruments = instruments;\n    this.start = Math.min(...instruments.map((i)=>i.start));\n    this.end = Math.max(...instruments.map((i)=>i.end));\n    this.length = this.end - this.start + 1;\n  }\n  /** All instruments available at tick */ on(tick) {\n    return new Market(this.instruments.filter((i)=>i.has(tick)));\n  }\n}\n/** Run simulation using strategy */ export class Backtest {\n  market;\n  strategy;\n  amount;\n  buy_commission;\n  sell_commission;\n  /** Series of available cash */ cash;\n  /** Series of value of positions */ invested;\n  /** Series of total value of account */ value;\n  /** Open Positions */ positions;\n  /** History of transactions */ transactions;\n  tick;\n  saldo;\n  constructor(/** Instruments available for simulation */ market\x2C /** Strategy for buying and selling */ strategy\x2C /** Initial amount of cash available for investing */ amount\x2C /** Percentage fee for buying */ buy_commission\x2C /** Percentage fee for selling */ sell_commission){\n    this.market = market;\n    this.strategy = strategy;\n    this.amount = amount;\n    this.buy_commission = buy_commission;\n    this.sell_commission = sell_commission;\n    this.positions = [];\n    this.transactions = [];\n    this.tick = 0;\n    this.saldo = 0;\n    const length = market.end - market.start + 1;\n    this.cash = new Float32Array(length);\n    this.invested = new Float32Array(length);\n    this.value = new Float32Array(length);\n    this.saldo = amount;\n  }\n  /** Open new position */ open(order) {\n    if (order.amount > this.saldo) return;\n    const position = {\n      instrument: order.instrument\x2C\n      quantity: order.amount / order.instrument.price(this.tick) * (1 - this.buy_commission)\x2C\n      start: this.tick\x2C\n      invested: order.amount\n    };\n    this.positions.push(position);\n    this.saldo -= order.amount;\n  }\n  /** Close existing position */ close(order\x2C price) {\n    const value = order.position.quantity * price;\n    const amount = value * (1 - this.sell_commission);\n    const profit = amount - order.position.invested;\n    this.positions.splice(this.positions.indexOf(order.position)\x2C 1);\n    const end = this.tick;\n    const position = order.position;\n    const reason = order.reason;\n    const closed = {\n      ...position\x2C\n      reason\x2C\n      end\x2C\n      profit\n    };\n    this.transactions.push(closed);\n    this.saldo += amount;\n  }\n  /** Expire position */ expire(position) {\n    const price = position.instrument.price(this.tick - 1);\n    this.close({\n      position\x2C\n      reason: "Expire"\n    }\x2C price);\n  }\n  /** Close positions where price data is no longer available */ liquidation() {\n    for (const position of this.positions.filter((p)=>p.instrument.end < this.tick))this.expire(position);\n  }\n  /** Process orders from strategy */ trade() {\n    const instruments = this.market.on(this.tick);\n    const orders = this.strategy(this.tick\x2C this.saldo\x2C instruments\x2C this.positions);\n    for (const order of orders){\n      if ("instrument" in order) this.open(order);\n      else this.close(order\x2C order.position.instrument.price(this.tick));\n    }\n  }\n  /** Update price series at end of each tick */ valuation() {\n    const index = this.tick - this.market.start;\n    this.cash[index] = this.saldo;\n    this.invested[index] = this.positions.map((p)=>p.quantity * p.instrument.price(this.tick)).reduce((a\x2C b)=>a + b\x2C 0);\n    this.value[index] = this.cash[index] + this.invested[index];\n  }\n  /** Execute actions for each tick */ step(tick) {\n    this.tick = tick;\n    this.liquidation();\n    this.trade();\n    this.valuation();\n  }\n  /** Run simulation */ run() {\n    for(let tick = this.market.start; tick <= this.market.end; ++tick){\n      this.step(tick);\n    }\n  }\n}\n
