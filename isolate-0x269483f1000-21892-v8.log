script-source,302,https://jsr.io/@sauber/statistics/0.4.0/mod.ts,/** Statistics of list of numbers */ /** Add all numbers together */ export const sum = (values)=>values.reduce((total\x2C a)=>total + a\x2C 0);\n/** Average of numbers */ export const avg = (values)=>sum(values) / values.length;\n/** Add a constant value to each number */ export const shift = (values\x2C offset)=>values.map((x)=>x + offset);\n/** Raise each value to power */ export const pow = (values\x2C exponent)=>values.map((x)=>Math.pow(x\x2C exponent));\n/** number * number */ export const squared = (values)=>values.map((x)=>x * x);\n/** Multiply pairs of numbers */ export const dot = (a\x2C b)=>a.map((_\x2C i)=>a[i] * b[i]);\n/** Standard Deviation */ export function std(values) {\n  const mean = avg(values);\n  const variances = shift(values\x2C -mean);\n  const sq = squared(variances);\n  const total = sum(sq);\n  const result = Math.sqrt(total / values.length);\n  return result;\n}\n/** Linear regression coeeficents */ export function regression(values) {\n  const sum = [\n    0\x2C\n    0\x2C\n    0\x2C\n    0\n  ];\n  values.forEach(function(value\x2C index) {\n    sum[0] += index;\n    sum[1] += value;\n    sum[2] += index * index;\n    sum[3] += index * value;\n  });\n  const len = values.length;\n  const run = len * sum[2] - sum[0] * sum[0];\n  const rise = len * sum[3] - sum[0] * sum[1];\n  const gradiant = run === 0 ? 0 : rise / run;\n  const intercept = sum[1] / len - gradiant * sum[0] / len;\n  return {\n    intercept: intercept\x2C\n    gradiant: gradiant\n  };\n}\n/** Calculate Pearson Correlation Coefficient of two datasets\n * @param a List of numbers in first set\n * @param b List of numbers in second set\n * @returns The numerical coefficient in range -1.0 to 1.0\n */ export function correlation(a\x2C b) {\n  // Confirm count if elements\n  if (a.length < 2 || b.length < 2) throw new Error(`Datasets must have at least 2 elements each.`);\n  // Confirm same length\n  if (a.length != b.length) throw new Error(`Datasets must have same length\x2C but have ${a.length} and ${b.length} elements.`);\n  // Calculate coefficient\n  const n = a.length;\n  const x = sum(a);\n  const y = sum(b);\n  const xx = sum(dot(a\x2C a));\n  const yy = sum(dot(b\x2C b));\n  const xy = sum(dot(a\x2C b));\n  const coefficient = (n * xy - x * y) / Math.sqrt((n * xx - x * x) * (n * yy - y * y));\n  return coefficient;\n}\n/** Box-Muller Normal Distribution Between 0 and 1 */ export function randn() {\n  let u = 0\x2C v = 0;\n  while(u === 0)u = Math.random(); // Converting [0\x2C1) to (0\x2C1)\n  while(v === 0)v = Math.random();\n  let num = Math.sqrt(-2.0 * Math.log(u)) * Math.cos(2.0 * Math.PI * v);\n  num = num / 10.0 + 0.5; // Translate to 0 -> 1\n  if (num > 1 || num < 0) return randn(); // resample between 0 and 1\n  return num;\n}\n/** Create signal with fewer data points */ export function downsample(input\x2C length) {\n  // No downsample if too little data\n  if (length >= input.length) return input;\n  // Divide signal into chunks and average each\n  const output = [];\n  const chunkSize = input.length / length;\n  for(let i = 1; i <= length; ++i)output.push(avg(input.slice(Math.floor((i - 1) * chunkSize)\x2C Math.ceil(i * chunkSize))));\n  return output;\n}\n
