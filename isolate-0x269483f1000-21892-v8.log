script-source,298,file:///C:/Users/msn/projects/deno-trading-backtest/src/benchmark_bin.ts,import { Backtest } from "./backtest.ts";\nimport { randomTrading } from "./strategies.ts";\nimport { makeMarket } from "./testinstrument.ts";\n// Create Market and Exchange\nconst market = makeMarket(500);\n// Create Strategy\nconst strategy = randomTrading;\n// Run Simulation many times\nfor(let i = 0; i < 1000; i++){\n  const simulation = new Backtest(market\x2C strategy\x2C 10000\x2C 0.001\x2C 0.001);\n  simulation.run();\n  const wins = simulation.transactions.filter((t)=>"end" in t && t.profit > 0).length;\n  const losses = simulation.transactions.filter((t)=>"end" in t && t.profit < 0).length;\n  const _winratio = wins / (wins + losses);\n}\n
